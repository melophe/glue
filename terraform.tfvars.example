# =============================================================================
# terraform.tfvars.example
# Copy this file to terraform.tfvars and fill in your values
# =============================================================================

# General
aws_region   = "ap-northeast-1"
environment  = "dev"
project_name = "glue-etl"

# S3 Parquet paths (replace with your actual paths)
s3_path_rds1   = "s3://your-bucket/rds1-export/"
s3_path_rds2   = "s3://your-bucket/rds2-export/"
s3_path_rds3   = "s3://your-bucket/rds3-export/"
s3_bucket_name = "your-bucket"

# RDS Configuration
rds_username          = "admin"
rds_password          = "YourSecurePassword123!"
rds_instance_class    = "db.t3.medium"
rds_allocated_storage = 20
rds_database_name     = "integrated_db"

# Schedule (UTC)
# Crawler: AM 1:00 JST = 16:00 UTC
# Job:     AM 2:00 JST = 17:00 UTC
crawler_schedule = "cron(0 16 * * ? *)"
job_schedule     = "cron(0 17 * * ? *)"

# Glue Job Configuration
glue_job_worker_type       = "G.1X"
glue_job_number_of_workers = 2
glue_version               = "4.0"

# Network
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["ap-northeast-1a", "ap-northeast-1c"]
